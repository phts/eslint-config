{
  "name": "@phts/eslint-config",
  "version": "2.1.1",
  "description": "My config for ESLint.",
  "main": "index.js",
  "files": [
    "addons/",
    "rules/",
    "index.js"
  ],
  "scripts": {
    "format": "eslint . --fix && prettier --write **/*.{md,json}",
    "lint": "eslint .",
    "lint:playground": "eslint --no-ignore --ext .js,.jsx,.ts,.tsx .",
    "preversion": "npm run lint && npm test",
    "test": "jest"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "peerDependencies": {
    "eslint": "^8.0.0",
    "prettier": "^2.0.0 || ^3.0.0",
    "typescript": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "prettier": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/phts/eslint-config.git"
  },
  "keywords": [
    "eslint",
    "eslint-config"
  ],
  "author": "Phil Tsaryk",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/phts/eslint-config/issues"
  },
  "homepage": "https://github.com/phts/eslint-config#readme",
  "dependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5"
  },
  "devDependencies": {
    "@phts/prettier-config": "^1.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.28",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "typescript": "^5.9.3"
  }
}
